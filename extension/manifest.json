{
  "manifest_version": 3,
  "name": "Stash",
  "version": "1.0.0",
  "description": "Save articles and bookmarks for later reading",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Stash - Reading List"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "save-page": {
      "suggested_key": {
        "default": "Ctrl+G",
        "mac": "MacCtrl+G"
      },
      "description": "Save current page to Stash"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "stash@localhost",
      "strict_min_version": "109.0"
    }
  }
}
